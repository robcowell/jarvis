<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/state_bad" />
            <solid android:color="#3CFf7C98" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#99FF7C98" />
            <solid android:color="#2215181D" />
        </shape>
    </item>
</selector>
