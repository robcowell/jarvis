<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootFrame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/bg_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="J.A.R.V.I.S."
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:shadowColor="#6636D8FF"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_label"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_value"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wake_label"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/wakeTopMetric"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wake_value"
                    android:textColor="@color/state_good"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="208dp"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_title"
                        android:textAllCaps="true"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/statusValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/status_idle"
                        android:textColor="@color/state_good"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/statusSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/status_sub_idle"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/controls_title"
                        android:textAllCaps="true"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                    <EditText
                        android:id="@+id/coreUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_console_box"
                        android:hint="@string/hint_core_url"
                        android:inputType="textUri"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/deviceIdInput"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_console_box"
                        android:hint="@string/hint_device_id"
                        android:inputType="text"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/locationInput"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_console_box"
                        android:hint="@string/hint_location"
                        android:inputType="text"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="11sp" />

                    <Switch
                        android:id="@+id/wakeWordSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/label_wake_word_enabled"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_panel"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="8dp">

                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp">

                    <View
                        android:layout_width="172dp"
                        android:layout_height="172dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_voice_ring_outer" />

                    <View
                        android:id="@+id/ringTickView"
                        android:layout_width="156dp"
                        android:layout_height="156dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_voice_ring_tick" />

                    <View
                        android:layout_width="138dp"
                        android:layout_height="138dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_voice_ring_middle" />

                    <View
                        android:layout_width="106dp"
                        android:layout_height="106dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_voice_ring_inner" />

                    <Button
                        android:id="@+id/listenButton"
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_voice_core"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"
                        android:text="@string/talk"
                        android:textAllCaps="true"
                        android:textColor="@color/accent"
                        android:textSize="15sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/heroCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Touch interface engaged"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/healthButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_action"
                        android:text="@string/button_health"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/versionButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_action"
                        android:text="@string/button_version"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/stopSpeechButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_critical"
                        android:text="@string/button_stop_speech"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/transcript_title"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/commandInput"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_console_box"
                    android:gravity="top|start"
                    android:hint="@string/hint_command"
                    android:inputType="textCapSentences|textMultiLine"
                    android:padding="8dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/sendButton"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_button_action"
                    android:text="@string/button_send_text_only"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/telemetry_title"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/outputView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_console_box"
                    android:fontFamily="monospace"
                    android:padding="10dp"
                    android:scrollbars="vertical"
                    android:textColor="@color/text_primary"
                    android:textIsSelectable="true"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Console: Android Native"
                android:textAllCaps="true"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="Core: Connected"
                android:textAllCaps="true"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_30"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>
